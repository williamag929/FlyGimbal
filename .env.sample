# ============================================================
# NX Sports — Football Probability Model
# Environment Variables
#
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================


# ------------------------------------------------------------
# AI Narrative (Claude)
# Required for AI-generated match analysis.
# Get your key at: https://console.anthropic.com/
# Without this key the system falls back to a structured
# plain-text summary — all probability output still works.
# ------------------------------------------------------------
ANTHROPIC_API_KEY=


# ------------------------------------------------------------
# Historical Match Data — football-data.org
# Free tier: 10 req/min, covers WC / EURO / AFCON competitions.
# Sign up at: https://www.football-data.org/client/register
# Leave blank to skip this source.
# ------------------------------------------------------------
FOOTBALL_DATA_KEY=


# ------------------------------------------------------------
# Historical Match Data — api-football (api-sports.io)
# Free tier: 100 req/day.
# Sign up at: https://dashboard.api-football.com/register
# Leave blank to skip this source.
# When both keys are set, football-data.org is tried first.
# ------------------------------------------------------------
API_FOOTBALL_KEY=


# ------------------------------------------------------------
# Cache
# Directory where fetched match records are cached as JSON.
# Relative to the working directory (or use an absolute path).
# Default: .football_cache
# ------------------------------------------------------------
FOOTBALL_CACHE_DIR=.football_cache


# ------------------------------------------------------------
# API Server (uvicorn)
# Used when running: uvicorn football.api.main:app
# ------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Comma-separated allowed origins for CORS.
# Use * to allow all (development only).
API_CORS_ORIGINS=*


# ------------------------------------------------------------
# Logging
# Standard Python log levels: DEBUG | INFO | WARNING | ERROR
# ------------------------------------------------------------
LOG_LEVEL=WARNING
